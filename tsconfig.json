{
	"compilerOptions": {
		"target": "ES2023",
		"module": "commonjs",
		"rootDir": "./",
		"outDir": "./dist",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"types": ["jest"]
	},
	"include": ["./src/**/*.ts", "./tests/**/*.ts"],
	"exclude": ["node_modules"]
}
